# OpenAI API 키 (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# 사용할 OpenAI 모델 (콘텐츠 생성)
OPENAI_MODEL=gpt-5.4

# Brave Search API 키 (https://api.search.brave.com)
BRAVE_API_KEY=your_brave_api_key_here

# Brave Search 결과 수 (기본 10)
BRAVE_SEARCH_COUNT=10

# Google Gemini API 키 (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 Gemini 모델 (디자인 기획)
GEMINI_MODEL=gemini-2.5-pro

# 사용할 Imagen 모델 (이미지 생성)
IMAGEN_MODEL=imagen-3.0-generate-001

# 생성된 PPT 저장 경로
OUTPUT_DIR=output

# 생성된 이미지 저장 경로
IMAGE_OUTPUT_DIR=output/images
